      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:bcg_class:nk]' type='palette'>
            <map to='#4e79a7'>
